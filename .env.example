# ========================================
# CONFIGURACIÓN PARA PRODUCCIÓN
# ========================================
# Copia este archivo a .env.local y reemplaza los valores
# ========================================

# ========================================
# GOOGLE ANALYTICS 4
# ========================================
# Obtén tu ID de GA4 en: https://analytics.google.com/
VITE_GA_ID=G-XXXXXXXXXX

# ========================================
# URL DEL SITIO
# ========================================
# Sin barra al final
VITE_SITE_URL=https://rpp.edu.mx

# ========================================
# METADATOS DEL SITIO
# ========================================
VITE_SITE_TITLE=Revista Panamericana de Pedagogía - RPP
VITE_SITE_DESCRIPTION=Plataforma científica y lúdica que ama resolver problemas educativos a través de la innovación transmedia.
VITE_SITE_KEYWORDS=pedagogía, educación, revista científica, transmedia, innovación educativa, investigación

# ========================================
# REDES SOCIALES
# ========================================
VITE_SOCIAL_TWITTER=@rpp_edu
VITE_SOCIAL_INSTAGRAM=@rpp_edu
VITE_SOCIAL_YOUTUBE=RPPedu

# ========================================
# CONTACTO
# ========================================
VITE_CONTACT_EMAIL=hola@rpp.edu.mx

# ========================================
# ANALYTICS DE VERCEL (OPCIONAL)
# ========================================
# Si despliegas en Vercel, puedes usar su analytics integrado
# Más info: https://vercel.com/analytics
VITE_VERCEL_ANALYTICS_ID=

# ========================================
# GOOGLE TAG MANAGER (OPCIONAL)
# ========================================
# Si usas GTM en lugar de GA directo
VITE_GTM_ID=GTM-XXXXXX

# ========================================
# SENTRY (OPCIONAL - Para monitoreo de errores)
# ========================================
VITE_SENTRY_DSN=

# ========================================
# NOTAS PARA DESPLIEGUE
# ========================================

## Vercel:
# 1. Ve a tu proyecto en Vercel
# 2. Settings → Environment Variables
# 3. Agrega cada variable con su valor
# 4. Haz redeploy para aplicar los cambios

## Netlify:
# 1. Ve a Site settings → Build & deploy → Environment
# 2. Agrega las variables
# 3. O usa un archivo .env en el root

## GitHub Pages:
# Las variables de entorno no funcionan en GitHub Pages
# Deberás hardcodear los valores en el código o usar
# un servicio externo para analytics

# ========================================
# SEO - CUÁNDO DESPLIEGUES
# ========================================
# 
# 1. Agrega react-helmet-async para meta tags dinámicos:
#    npm install react-helmet-async
#
# 2. Crea un componente Helmet en src/components/Helmet.tsx
#
# 3. Importa y usa en cada sección del App.tsx
#
# 4. Genera un sitemap.xml (puedes usar: https://www.sitemapxml.net/)
#
# 5. Crea robots.txt en la carpeta public/
#
# 6. Registra tu sitio en:
#    - Google Search Console
#    - Bing Webmaster Tools
#    - Yandex Webmaster (si es relevante)

# ========================================
# ANALYTICS - CUÁNDO DESPLIEGUES
# ========================================
#
# Opción 1: Google Analytics 4 (Recomendado)
# 1. Crea propiedad en analytics.google.com
# 2. Copia tu ID de medición (G-XXXXXXXXXX)
# 3. Instancia el componente en main.tsx o App.tsx
#
# Opción 2: Vercel Analytics (Si usas Vercel)
# 1. npm install @vercel/analytics
# 2. Importa y usa en main.tsx
# 3. Ve a vercel.com/dashboard/analytics
#
# Opción 3: Plausible Analytics (Privado, sin cookies)
# 1. https://plausible.io/
# 2. Más ligero que GA
# 3. Cumple con GDPR automáticamente
